{
    "env": {
        "browser": true,
        "commonjs": true,
        "es2021": true,
        "node": true
    },
    "extends": [
        "eslint:recommended",
        "plugin:@typescript-eslint/recommended",
        "prettier"
    ],
    "parserOptions": {
        "ecmaVersion": "latest"
    },
    "rules": {
        "semi": ["warn", "always"],
        "quotes": ["warn", "double"],
        "arrow-parens": ["warn", "always"],
        "no-unused-vars": "warn",
        "no-console": "off",
        "import/prefer-default-export": "off"
    }
}
